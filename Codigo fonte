let obra
let resposta
let lista
let resposta1
let nota
let analise
let statusCurtida = false
let statusConcluido = false
let episodiosVistos = 0
let nomeObra

let obras = []

function pesquisar_obra() {
    if (resposta == "filme") {
        nomeObra = prompt("Que filme você quer ver? ")
    } else if (resposta == "serie" || resposta == "série") {
        nomeObra = prompt("Que série você quer ver? ")
    } else {
        console.log("Tipo de obra inválido!")
    }
}

function adicionar_obra() {
    if (resposta1 == "sim") {

        let obraInfo = {
            nome: nomeObra,
            tipo: resposta,
            nota: null,
            analise: "",
            curtida: false,
            concluida: false,
            episodios: 0
        }

        obras.push(obraInfo)

        console.log("Obra adicionada!")
    }
}

function avaliar_obra() {

    let obraAvaliada = prompt("Digite o nome da obra que deseja avaliar: ")

    let indice = -1

    for (let i = 0; i < obras.length; i++) {
        if (obras[i].nome.toLowerCase() == obraAvaliada.toLowerCase()) {
            indice = i
            break
        }
    }

    if (indice == -1) {
        console.log("Obra não encontrada!")
        return
    }

    nota = parseFloat(prompt("Dê uma nota de 0 a 5 estrelas para a obra: "))
    analise = prompt("Escreva sua análise sobre a obra: ")

    let curtiu = prompt("Você curtiu a obra? (sim/não) ").toLowerCase()

    statusCurtida = false
    statusConcluido = false
    episodiosVistos = 0

    if (curtiu == "sim") {
        statusCurtida = true
    }

    if (obras[indice].tipo == "filme") {

        let concluiu = prompt("Você assistiu o filme até o final? (sim/não) ").toLowerCase()

        if (concluiu == "sim") {
            statusConcluido = true
        }

    } else if (obras[indice].tipo == "serie" || obras[indice].tipo == "série") {

        let tipoSerie = prompt("Você quer avaliar a série inteira ou um episódio específico? (inteira/episodio) ").toLowerCase()

        if (tipoSerie == "inteira") {

            let concluiu = prompt("Você concluiu a série? (sim/não) ").toLowerCase()

            if (concluiu == "sim") {
                statusConcluido = true
            } else {
                episodiosVistos = parseInt(prompt("Quantos episódios você já assistiu? "))
            }

        } else if (tipoSerie == "episodio") {

            let ep = parseInt(prompt("Qual episódio você quer avaliar? "))
            console.log("Você está avaliando o episódio " + ep)

        }
    }

    obras[indice].nota = nota
    obras[indice].analise = analise
    obras[indice].curtida = statusCurtida
    obras[indice].concluida = statusConcluido
    obras[indice].episodios = episodiosVistos

    console.log("Nota atribuída: " + nota)
    console.log("Análise: " + analise)
}

function listar_obras() {

    console.log("===== LISTA DE OBRAS =====")

    for (let i = 0; i < obras.length; i++) {

        console.log("Nome: " + obras[i].nome)
        console.log("Tipo: " + obras[i].tipo)
        console.log("Nota: " + obras[i].nota)
        console.log("Análise: " + obras[i].analise)
        console.log("Curtida: " + obras[i].curtida)
        console.log("Concluída: " + obras[i].concluida)
        console.log("Episódios vistos: " + obras[i].episodios)
        console.log("----------------------")
    }
}

function pesquisar_cadastrada() {

    let busca = prompt("Digite o nome da obra que deseja procurar: ")
    let encontrada = false

    for (let i = 0; i < obras.length; i++) {

        if (obras[i].nome.toLowerCase() == busca.toLowerCase()) {

            console.log("===== OBRA ENCONTRADA =====")
            console.log("Nome: " + obras[i].nome)
            console.log("Tipo: " + obras[i].tipo)
            console.log("Nota: " + obras[i].nota)
            console.log("Análise: " + obras[i].analise)

            encontrada = true
        }
    }

    if (encontrada == false) {
        console.log("Obra não encontrada!")
    }
}

function menu() {

    let opcao = ""

    while (opcao != "5") {

        console.log("===== MENU =====")
        console.log("1 - Pesquisar obra")
        console.log("2 - Avaliar obra")
        console.log("3 - Listar obras")
        console.log("4 - Procurar obra cadastrada")
        console.log("5 - Sair")

        opcao = prompt("Escolha uma opção: ")

        if (opcao == "1") {

            obra = prompt("Você quer ver um filme ou uma série? ")
            resposta = obra.toLowerCase()

            pesquisar_obra()

            lista = prompt("Você deseja adicionar a obra na lista de desejos? ")
            resposta1 = lista.toLowerCase()

            adicionar_obra()

        } else if (opcao == "2") {

            avaliar_obra()

        } else if (opcao == "3") {

            listar_obras()

        } else if (opcao == "4") {

            pesquisar_cadastrada()

        } else if (opcao == "5") {

            console.log("Programa encerrado!")

        } else {

            console.log("Opção inválida!")
        }
    }
}

menu()
