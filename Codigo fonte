let nota
let analise
let statusCurtida = false
let statusConcluido = false
let episodiosVistos = 0

function avaliar_obra() {
    nota = parseFloat(prompt("Dê uma nota de 0 a 5 estrelas para a obra"))
    analise = prompt("Escreva sua análise sobre a obra")

    let curtiu = prompt("Você curtiu a obra? (sim/não)").toLowerCase()
    if (curtiu == "sim") {
        statusCurtida = true
    }

    if (resposta == "série") {
        let tipoSerie = prompt("Você quer avaliar a série inteira ou um episódio específico? (inteira/episodio)").toLowerCase()

        if (tipoSerie == "inteira") {
            let concluiu = prompt("Você concluiu a série? (sim/não)").toLowerCase()
            if (concluiu == "sim") {
                statusConcluido = true
            } else {
                episodiosVistos = parseInt(prompt("Quantos episódios você já assistiu?"))
            }
        } else if (tipoSerie == "episodio") {
            let ep = parseInt(prompt("Qual episódio você quer avaliar?"))
            console.log("Você está avaliando o episódio " + ep)
        }
    }

    console.log("Nota atribuída: " + nota)
    console.log("Análise: " + analise)
}

